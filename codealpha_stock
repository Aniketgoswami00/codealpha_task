stocks = {
    "AAPL": 180,
    "TSLA": 250,
    "GOOGLE": 300
}

total = 0

print("STOCK PORTFOLIO TRACKER")

while True:

    stock = input("Enter stock name (EXIT to stop): ").upper()

    if stock == "EXIT":
        break

    if stock in stocks:

        quantity = int(input("Enter quantity: "))

        total += stocks[stock] * quantity

    else:
        print("Stock not available")

print("\nTotal Investment =", total)

file = open("portfolio.txt", "w")

file.write("Total Investment = " + str(total))

file.close()

print("Saved in portfolio.txt")